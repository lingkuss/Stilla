{
  "name": "vindla",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/share", "destination": "/share.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}
