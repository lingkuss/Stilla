OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini
PORT=8787
REDIS_URL=redis://...

# App Attest configuration
APP_ATTEST_REQUIRED=true
APPLE_TEAM_ID=YOUR_TEAM_ID
IOS_BUNDLE_ID=com.your.bundleid
APP_ATTEST_ALLOW_DEVELOPMENT=true
APP_AUTH_TOKEN_SECRET=replace_with_a_very_long_random_secret
APP_AUTH_TOKEN_TTL_SECONDS=900
APP_ATTEST_CHALLENGE_TTL_SECONDS=120
APP_ATTEST_MAX_CLOCK_SKEW_SECONDS=180

# Optional transition support for old Bearer token auth.
# Keep false in production.
ALLOW_LEGACY_PROXY_TOKEN=false
KAI_PROXY_TOKEN=
