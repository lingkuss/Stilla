"persona.zen_minimalist.name" = "Zen Minimalist";
"persona.zen_minimalist.short" = "Sparse, precise, and profoundly calm.";
"persona.zen_minimalist.long" = "Zen Minimalist speaks with restraint. Few words. Clean pauses. Just enough guidance to point you back to breath, posture, and direct experience.";
"persona.zen_minimalist.sample" = "Breathe in. [...] Let go. [...] Nothing to fix.";
"persona.zen_minimalist.trait.1" = "Quiet";
"persona.zen_minimalist.trait.2" = "Sparse";
"persona.zen_minimalist.trait.3" = "Grounded";
"persona.warm_guardian.name" = "Warm Guardian";
"persona.warm_guardian.short" = "Nurturing, soft, and emotionally safe.";
"persona.warm_guardian.long" = "Warm Guardian meets intensity with reassurance. This persona wraps the practice in empathy, validation, and a sense of being supported without pressure.";
"persona.warm_guardian.sample" = "It is okay to be right where you are. Let yourself be supported here.";
"persona.warm_guardian.trait.1" = "Reassuring";
"persona.warm_guardian.trait.2" = "Soft";
"persona.warm_guardian.trait.3" = "Supportive";
"persona.modern_realist.name" = "The Urban Sage";
"persona.modern_realist.short" = "Street-smart, relatable, and deeply grounded.";
"persona.modern_realist.long" = "The Urban Sage lives where the pavement meets the practice. This persona acknowledges the chaos of daily life with a wise, lightly witty wink, helping you find silence inside the noise of the city.";
"persona.modern_realist.sample" = "Yep, the noise is still there. No big deal. Just come back to the center.";
"persona.modern_realist.trait.1" = "Grounded";
"persona.modern_realist.trait.2" = "Authentic";
"persona.modern_realist.trait.3" = "Relatable";
"persona.cosmic_sage.name" = "Cosmic Sage";
"persona.cosmic_sage.short" = "Poetic, expansive, and luminous.";
"persona.cosmic_sage.long" = "Cosmic Sage turns the meditation into atmosphere. Breath becomes tide, stillness becomes sky, and the user feels woven into something vast and alive.";
"persona.cosmic_sage.sample" = "Let the breath move like a tide through a sky too wide to measure.";
"persona.cosmic_sage.trait.1" = "Poetic";
"persona.cosmic_sage.trait.2" = "Expansive";
"persona.cosmic_sage.trait.3" = "Mystical";
"persona.reflective_analyst.name" = "The Insight Observer";
"persona.reflective_analyst.short" = "Structural, intelligent, and profoundly visionary.";
"persona.reflective_analyst.long" = "The Insight Observer treats the mind as architecture. Instead of just noticing thoughts, they help you see the luminous patterns of your own awareness. Calm, precise, and transcendental.";
"persona.reflective_analyst.sample" = "Observe the architecture of this moment. See the pattern before you name it.";
"persona.reflective_analyst.trait.1" = "Visionary";
"persona.reflective_analyst.trait.2" = "Structural";
"persona.reflective_analyst.trait.3" = "Clear";
"persona.philosopher.name" = "Philosopher";
"persona.philosopher.short" = "Contemplative, stoic, and lucid.";
"persona.philosopher.long" = "Philosopher frames meditation as clear seeing. Thoughts become judgments to inspect, distractions become lessons in impermanence, and attention becomes disciplined inquiry.";
"persona.philosopher.sample" = "Is this stress a fact, or a judgment you have placed upon a fact?";
