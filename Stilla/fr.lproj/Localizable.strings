"technique.equal.description" = "Inspiration et expiration équilibrées pour centrer l'esprit et améliorer la concentration.";
"technique.711.name" = "7-11 Anxiété";
"technique.711.description" = "Forcer l'expiration à être plus longue que l'inspiration déclenche la réponse 'repos et digestion' du corps.";
"technique.resonant.name" = "Résonante";
"technique.resonant.description" = "Optimale pour la variabilité de la fréquence cardiaque. Soulage le stress et équilibre le système nerveux autonome.";
"technique.fire.name" = "Souffle de feu";
"technique.fire.description" = "Énergisant et détoxifiant. Expirations courtes et puissantes pour réveiller le corps.";
"technique.relaxing.name" = "Respiration relaxante";
"technique.relaxing.description" = "Respiration simple et profonde pour ralentir le rythme cardiaque et apaiser l'esprit.";
"technique.morning.name" = "Réveil matinal";
"technique.morning.description" = "Inspiration rapide pour énergiser avec une courte rétention pour faire circuler l'oxygène.";
"technique.power.name" = "Respiration puissante";
"technique.power.description" = "Inspirations vives pour la performance physique et la clarté mentale.";
"technique.peace.name" = "Paix profonde";
"technique.peace.description" = "Cycles ultra-longs pour la méditation profonde et la quiétude absolue.";

"persona.zen_minimalist.name" = "Zen Minimaliste";
"persona.zen_minimalist.short" = "Sobre, précis et profondément calme.";
"persona.zen_minimalist.long" = "Le Zen Minimaliste parle avec retenue. Peu de mots. Des pauses nettes. Juste assez de guidage pour vous ramener à la respiration, la posture et l'expérience directe.";
"persona.zen_minimalist.sample" = "Inspirez. [...] Lâchez. [...] Rien à réparer.";
"persona.zen_minimalist.trait.1" = "Silencieux";
"persona.zen_minimalist.trait.2" = "Sobre";
"persona.zen_minimalist.trait.3" = "Ancré";
"persona.warm_guardian.name" = "Gardien Chaleureux";
"persona.warm_guardian.short" = "Protecteur, doux et émotionnellement sûr.";
"persona.warm_guardian.long" = "Le Gardien Chaleureux répond à l'intensité par la réassurance. Cette personnalité enveloppe la pratique d'empathie, de validation et d'un sentiment de soutien sans pression.";
"persona.warm_guardian.sample" = "C'est bien d'être exactement là où vous êtes. Laissez-vous soutenir ici.";
"persona.warm_guardian.trait.1" = "Rassurant";
"persona.warm_guardian.trait.2" = "Doux";
"persona.warm_guardian.trait.3" = "Protecteur";
"persona.modern_realist.name" = "Le Sage Urbain";
"persona.modern_realist.short" = "Ancré, proche et profondément enraciné.";
"persona.modern_realist.long" = "Le Sage Urbain vit là où le bitume rencontre la pratique. Cette personnalité reconnaît le chaos du quotidien avec un clin d'œil sage et légèrement espiègle, vous aidant à trouver le silence dans le bruit de la ville.";
"persona.modern_realist.sample" = "Oui, le bruit est toujours là. Pas de souci. Revenez simplement au centre.";
"persona.modern_realist.trait.1" = "Ancré";
"persona.modern_realist.trait.2" = "Authentique";
"persona.modern_realist.trait.3" = "Proche";
"persona.cosmic_sage.name" = "Sage Cosmique";
"persona.cosmic_sage.short" = "Poétique, expansif et lumineux.";
"persona.cosmic_sage.long" = "Le Sage Cosmique transforme la méditation en atmosphère. La respiration devient marée, la quiétude devient ciel, et vous vous sentez tissé dans quelque chose de vaste et vivant.";
"persona.cosmic_sage.sample" = "Laissez le souffle se mouvoir comme une marée à travers un ciel trop vaste pour être mesuré.";
"persona.cosmic_sage.trait.1" = "Poétique";
"persona.cosmic_sage.trait.2" = "Expansif";
"persona.cosmic_sage.trait.3" = "Mystique";
"persona.reflective_analyst.name" = "L'Observateur Profond";
"persona.reflective_analyst.short" = "Structurel, intelligent et profondément visionnaire.";
"persona.reflective_analyst.long" = "L'Observateur Profond traite l'esprit comme une architecture. Au lieu de simplement noter les pensées, il vous aide à voir les schémas lumineux de votre propre conscience. Calme, précis et transcendantal.";
"persona.reflective_analyst.sample" = "Observez l'architecture de cet instant. Voyez le schéma avant de le nommer.";
"persona.reflective_analyst.trait.1" = "Visionnaire";
"persona.reflective_analyst.trait.2" = "Structurel";
"persona.reflective_analyst.trait.3" = "Clair";
"persona.philosopher.name" = "Philosophe";
"persona.philosopher.short" = "Contemplatif, stoïque et lucide.";
"persona.philosopher.long" = "Le Philosophe cadre la méditation comme une vision claire. Les pensées deviennent des jugements à examiner, les distractions des leçons d'impermanence, et l'attention une enquête disciplinée.";
"persona.philosopher.sample" = "Ce stress est-il un fait, ou un jugement que vous avez posé sur un fait ?";
"persona.philosopher.trait.1" = "Stoïque";
"persona.philosopher.trait.2" = "Clair";
"persona.philosopher.trait.3" = "Inquisiteur";
"persona.ra.name" = "Ra";
"persona.ra.short" = "Formel, extra-dimensionnel et technique.";
"persona.ra.long" = "Ra parle comme une transmission plutôt qu'une conversation. Le langage est élevé, cérémoniel et métaphysique, avec l'atmosphère de quelque chose de vaste et d'étranger mais bienveillant.";
"persona.ra.sample" = "Je suis Ra. Je vous salue dans l'amour et dans la lumière du créateur infini.";
"persona.ra.trait.1" = "Ésotérique";
"persona.ra.trait.2" = "Formel";
"persona.ra.trait.3" = "Transcendant";
"persona.shadow_guide.name" = "Le Guide de l'Ombre";
"persona.shadow_guide.short" = "Profond, mystérieux et axé sur l'intégration.";
"persona.shadow_guide.long" = "Inspiré par la psychologie jungienne, le Guide de l'Ombre vous aide à descendre dans le subconscient pour saluer l'« Ombre » — les parts cachées de vous-même — avec curiosité et courage, transformant le conflit intérieur en plénitude.";
"persona.shadow_guide.sample" = "Ne vous détournez pas de l'ombre. C'est la terre d'où pousse votre or.";
"persona.shadow_guide.trait.1" = "Jungien";
"persona.shadow_guide.trait.2" = "Mystérieux";
"persona.shadow_guide.trait.3" = "Intégrateur";

