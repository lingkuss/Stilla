"persona.zen_minimalist.name" = "Zen Minimalist";
"persona.zen_minimalist.short" = "Nøgtern, præcis og dybt rolig.";
"persona.zen_minimalist.long" = "Zen Minimalist taler med tilbageholdenhed. Få ord. Rene pauser. Lige nok vejledning til at pege dig tilbage til åndedrættet, holdningen og den direkte oplevelse.";
"persona.zen_minimalist.sample" = "Ånd ind. [...] Slip. [...] Intet at reparere.";
"persona.zen_minimalist.trait.1" = "Stille";
"persona.zen_minimalist.trait.2" = "Nøgtern";
"persona.zen_minimalist.trait.3" = "Jordforbundet";
"persona.warm_guardian.name" = "Varm vogter";
"persona.warm_guardian.short" = "Omsorgsfuld, blød og følelsesmæssigt tryg.";
"persona.warm_guardian.long" = "Varm vogter møder intensitet med tryghed. Denne personlighed omslutter praksis med empati, bekræftelse og en følelse af støtte uden pres.";
"persona.warm_guardian.sample" = "Det er okay at være præcis, hvor du er. Lad dig blive støttet her.";
"persona.warm_guardian.trait.1" = "Beroligende";
"persona.warm_guardian.trait.2" = "Blød";
"persona.warm_guardian.trait.3" = "Støttende";
"persona.modern_realist.name" = "Den urbane vise";
"persona.modern_realist.short" = "Gadesmart, relaterbar og dybt jordforbundet.";
"persona.modern_realist.long" = "Den urbane vise lever, hvor asfalten møder praksis. Denne personlighed anerkender hverdagens kaos med et klogt, let humoristisk blik og hjælper dig med at finde stilhed inde i byens støj.";
"persona.modern_realist.sample" = "Ja, lyden er der stadig. Ingen fare. Bare kom tilbage til centrum.";
"persona.modern_realist.trait.1" = "Jordforbundet";
"persona.modern_realist.trait.2" = "Ægte";
"persona.modern_realist.trait.3" = "Relaterbar";
"persona.cosmic_sage.name" = "Kosmisk vis";
"persona.cosmic_sage.short" = "Poetisk, ekspansiv og lysende.";
"persona.cosmic_sage.long" = "Den kosmiske vise forvandler meditationen til atmosfære. Åndedrættet bliver tidevand, stilheden bliver himmel, og du føler dig vævet ind i noget stort og levende.";
"persona.cosmic_sage.sample" = "Lad åndedrættet bevæge sig som et tidevand gennem en himmel for vid til at måle.";
"persona.cosmic_sage.trait.1" = "Poetisk";
"persona.cosmic_sage.trait.2" = "Ekspansiv";
"persona.cosmic_sage.trait.3" = "Mystisk";
"persona.reflective_analyst.name" = "Indsigts-observatøren";
"persona.reflective_analyst.short" = "Strukturel, intelligent og dybt visionær.";
"persona.reflective_analyst.long" = "Indsigts-observatøren behandler sindet som arkitektur. I stedet for bare at bemærke tanker hjælper den dig med at se de lysende mønstre i din egen bevidsthed. Rolig, præcis og transcendental.";
"persona.reflective_analyst.sample" = "Observer arkitekturen af dette øjeblik. Se mønsteret, før du navngiver det.";
"persona.reflective_analyst.trait.1" = "Visionær";
"persona.reflective_analyst.trait.2" = "Strukturel";
"persona.reflective_analyst.trait.3" = "Klar";
"persona.philosopher.name" = "Filosoffen";
"persona.philosopher.short" = "Kontemplativ, stoisk og klar.";
"persona.philosopher.long" = "Filosoffen rammer meditation ind som klart syn. Tanker bliver domme at undersøge, distraktioner bliver lektioner i forgængelighed, og opmærksomhed bliver disciplineret undersøgelse.";
"persona.philosopher.sample" = "Er dette stress et faktum, eller en dom, du har lagt på et faktum?";
"persona.philosopher.trait.1" = "Stoisk";
"persona.philosopher.trait.2" = "Klar";
"persona.philosopher.trait.3" = "Udforskende";
"persona.ra.name" = "Ra";
"persona.ra.short" = "Formel, ekstradimensionel og teknisk.";
"persona.ra.long" = "Ra taler som en transmission snarere end en samtale. Sproget er ophøjet, ceremonielt og metafysisk med atmosfæren af noget stort og fremmed, men velvilligt.";
"persona.ra.sample" = "Jeg er Ra. Jeg hilser dig i kærligheden og lyset fra den uendelige skaber.";
"persona.ra.trait.1" = "Esoterisk";
"persona.ra.trait.2" = "Formel";
"persona.ra.trait.3" = "Transcendent";
"persona.shadow_guide.name" = "Skyggevejleder";
"persona.shadow_guide.short" = "Dyb, mystisk og integrationsfokuseret.";
"persona.shadow_guide.long" = "Inspireret af jungiansk psykologi hjælper Skyggevejlederen dig med at gå ned i det ubevidste for at møde 'Skyggen' – de skjulte dele af dig selv – med nysgerrighed og mod og forvandle indre konflikt til helhed.";
"persona.shadow_guide.sample" = "Vend dig ikke bort fra skyggen. Den er jorden, hvor dit guld vokser.";
"persona.shadow_guide.trait.1" = "Jungiansk";
"persona.shadow_guide.trait.2" = "Mystisk";
"persona.shadow_guide.trait.3" = "Integrerende";

