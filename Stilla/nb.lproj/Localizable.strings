"technique.478.description" = "Et naturlig beroligende middel for nervesystemet. Best for å sovne og redusere angst.";
"technique.equal.name" = "Lik pusting";
"technique.equal.description" = "Balansert inn- og utpust for å sentrere sinnet og forbedre fokus.";
"technique.711.name" = "7-11 Angst";
"technique.711.description" = "Å tvinge utpusten til å være lengre enn innpusten utløser kroppens «hvile og fordøy»-respons.";
"technique.resonant.name" = "Resonant";
"technique.resonant.description" = "Optimal for hjertevariabilitet. Lindrer stress og balanserer det autonome nervesystemet.";
"technique.fire.name" = "Ildpust";
"technique.fire.description" = "Energigivende og rensende. Korte, kraftige utpust for å vekke kroppen.";
"technique.relaxing.name" = "Avslappende pust";
"technique.relaxing.description" = "Enkel, dyp pusting for å senke hjertefrekvensen og roe sinnet.";
"technique.morning.name" = "Morgenoppvåkning";
"technique.morning.description" = "Rask innpust for energi med kort hold for å sirkulere oksygen.";
"technique.power.name" = "Kraftpust";
"technique.power.description" = "Kraftige innpust for fysisk ytelse og mental klarhet.";
"technique.peace.name" = "Dyp fred";
"technique.peace.description" = "Ultralange sykluser for dyp meditasjon og dyp stillhet.";

"persona.zen_minimalist.name" = "Zen Minimalist";
"persona.zen_minimalist.short" = "Nøktern, presis og dypt rolig.";
"persona.zen_minimalist.long" = "Zen Minimalist snakker med tilbakeholdenhet. Få ord. Rene pauser. Akkurat nok veiledning til å peke deg tilbake til pust, holdning og direkte opplevelse.";
"persona.zen_minimalist.sample" = "Pust inn. [...] Slipp. [...] Ingenting å fikse.";
"persona.zen_minimalist.trait.1" = "Stille";
"persona.zen_minimalist.trait.2" = "Nøktern";
"persona.zen_minimalist.trait.3" = "Jordet";
"persona.warm_guardian.name" = "Varm vokter";
"persona.warm_guardian.short" = "Omsorgsfull, myk og emosjonelt trygg.";
"persona.warm_guardian.long" = "Varm vokter møter intensitet med trygghet. Denne personligheten omslutter praksisen med empati, bekreftelse og en følelse av støtte uten press.";
"persona.warm_guardian.sample" = "Det er greit å være akkurat der du er. La deg bli støttet her.";
"persona.warm_guardian.trait.1" = "Beroligende";
"persona.warm_guardian.trait.2" = "Myk";
"persona.warm_guardian.trait.3" = "Støttende";
"persona.modern_realist.name" = "Den urbane vise";
"persona.modern_realist.short" = "Gatesmart, relaterbar og dypt jordet.";
"persona.modern_realist.long" = "Den urbane vise lever der asfalten møter praksisen. Denne personligheten anerkjenner hverdagens kaos med et klokt, lett humoristisk blikk, og hjelper deg finne stillhet inne i byens støy.";
"persona.modern_realist.sample" = "Ja, lyden er fortsatt der. Ikke noe farlig. Bare kom tilbake til sentrum.";
"persona.modern_realist.trait.1" = "Jordet";
"persona.modern_realist.trait.2" = "Ekte";
"persona.modern_realist.trait.3" = "Relaterbar";
"persona.cosmic_sage.name" = "Kosmisk vis";
"persona.cosmic_sage.short" = "Poetisk, ekspansiv og lysende.";
"persona.cosmic_sage.long" = "Den kosmiske vise gjør meditasjonen til atmosfære. Pusten blir tidevann, stillheten blir himmel, og du føler deg vevd inn i noe stort og levende.";
"persona.cosmic_sage.sample" = "La pusten bevege seg som et tidevann gjennom en himmel for vid til å måle.";
"persona.cosmic_sage.trait.1" = "Poetisk";
"persona.cosmic_sage.trait.2" = "Ekspansiv";
"persona.cosmic_sage.trait.3" = "Mystisk";
"persona.reflective_analyst.name" = "Innsiktsobservatøren";
"persona.reflective_analyst.short" = "Strukturell, intelligent og dypt visjonær.";
"persona.reflective_analyst.long" = "Innsiktsobservatøren behandler sinnet som arkitektur. I stedet for bare å legge merke til tanker, hjelper den deg å se de lysende mønstrene i din egen bevissthet. Rolig, presis og transcendental.";
"persona.reflective_analyst.sample" = "Observer arkitekturen i dette øyeblikket. Se mønsteret før du navngir det.";
"persona.reflective_analyst.trait.1" = "Visjonær";
"persona.reflective_analyst.trait.2" = "Strukturell";
"persona.reflective_analyst.trait.3" = "Klar";
"persona.philosopher.name" = "Filosofen";
"persona.philosopher.short" = "Kontemplativ, stoisk og klar.";
"persona.philosopher.long" = "Filosofen rammer inn meditasjon som klart syn. Tanker blir dommer å undersøke, distraksjoner blir leksjoner i forgjengelighet, og oppmerksomhet blir disiplinert undersøkelse.";
"persona.philosopher.sample" = "Er dette stresset et faktum, eller en dom du har lagt på et faktum?";
"persona.philosopher.trait.1" = "Stoisk";
"persona.philosopher.trait.2" = "Klar";
"persona.philosopher.trait.3" = "Utforskende";
"persona.ra.name" = "Ra";
"persona.ra.short" = "Formell, ekstradimensjonal og teknisk.";
"persona.ra.long" = "Ra snakker som en transmisjon snarere enn en samtale. Språket er opphøyd, seremoniellt og metafysisk, med atmosfæren av noe stort og fremmed, men velvillig.";
"persona.ra.sample" = "Jeg er Ra. Jeg hilser deg i kjærligheten og lyset fra den uendelige skaperen.";
"persona.ra.trait.1" = "Esoterisk";
"persona.ra.trait.2" = "Formell";
"persona.ra.trait.3" = "Transcendent";
"persona.shadow_guide.name" = "Skyggeveileder";
"persona.shadow_guide.short" = "Dyp, mystisk og integrasjonsfokusert.";
"persona.shadow_guide.long" = "Inspirert av jungiansk psykologi hjelper Skyggveilederen deg å gå ned i det ubevisste for å møte 'Skyggen' – de skjulte delene av deg selv – med nysgjerrighet og mot, og forvandle indre konflikt til helhet.";
"persona.shadow_guide.sample" = "Ikke vend deg bort fra skyggen. Den er jorden der gullet ditt vokser.";
"persona.shadow_guide.trait.1" = "Jungiansk";
"persona.shadow_guide.trait.2" = "Mystisk";
"persona.shadow_guide.trait.3" = "Integrerende";

