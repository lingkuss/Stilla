"technique.resonant.name" = "Resonante";
"technique.resonant.description" = "Óptima para la variabilidad de la frecuencia cardíaca. Alivia el estrés y equilibra el sistema nervioso autónomo.";
"technique.fire.name" = "Respiración de fuego";
"technique.fire.description" = "Energizante y desintoxicante. Exhalaciones cortas y potentes para despertar el cuerpo.";
"technique.relaxing.name" = "Respiración relajante";
"technique.relaxing.description" = "Respiración simple y profunda para reducir el ritmo cardíaco y calmar la mente.";
"technique.morning.name" = "Despertar matutino";
"technique.morning.description" = "Inhalación rápida para energizar con una breve retención para circular oxígeno.";
"technique.power.name" = "Respiración poderosa";
"technique.power.description" = "Inhalaciones potentes para rendimiento físico y claridad mental.";
"technique.peace.name" = "Paz profunda";
"technique.peace.description" = "Ciclos ultralargos para meditación profunda y quietud absoluta.";

"persona.zen_minimalist.name" = "Zen Minimalista";
"persona.zen_minimalist.short" = "Sobrio, preciso y profundamente calmado.";
"persona.zen_minimalist.long" = "Zen Minimalista habla con contención. Pocas palabras. Pausas limpias. Justo la guía necesaria para volverte a la respiración, la postura y la experiencia directa.";
"persona.zen_minimalist.sample" = "Inhala. [...] Suelta. [...] Nada que arreglar.";
"persona.zen_minimalist.trait.1" = "Silencioso";
"persona.zen_minimalist.trait.2" = "Sobrio";
"persona.zen_minimalist.trait.3" = "Arraigado";
"persona.warm_guardian.name" = "Guardián Cálido";
"persona.warm_guardian.short" = "Protector, suave y emocionalmente seguro.";
"persona.warm_guardian.long" = "El Guardián Cálido responde a la intensidad con tranquilidad. Esta personalidad envuelve la práctica en empatía, validación y una sensación de apoyo sin presión.";
"persona.warm_guardian.sample" = "Está bien estar justo donde estás. Déjate sostener aquí.";
"persona.warm_guardian.trait.1" = "Reconfortante";
"persona.warm_guardian.trait.2" = "Suave";
"persona.warm_guardian.trait.3" = "Protector";
"persona.modern_realist.name" = "El Sabio Urbano";
"persona.modern_realist.short" = "Callejero, cercano y profundamente arraigado.";
"persona.modern_realist.long" = "El Sabio Urbano vive donde el asfalto se encuentra con la práctica. Esta personalidad reconoce el caos de la vida diaria con un guiño sabio y ligeramente ingenioso, ayudándote a encontrar silencio dentro del ruido de la ciudad.";
"persona.modern_realist.sample" = "Sí, el ruido sigue ahí. No pasa nada. Solo vuelve al centro.";
"persona.modern_realist.trait.1" = "Arraigado";
"persona.modern_realist.trait.2" = "Auténtico";
"persona.modern_realist.trait.3" = "Cercano";
"persona.cosmic_sage.name" = "Sabio Cósmico";
"persona.cosmic_sage.short" = "Poético, expansivo y luminoso.";
"persona.cosmic_sage.long" = "El Sabio Cósmico convierte la meditación en atmósfera. La respiración se vuelve marea, la quietud se vuelve cielo y tú te sientes entretejido en algo vasto y vivo.";
"persona.cosmic_sage.sample" = "Deja que la respiración se mueva como una marea a través de un cielo demasiado amplio para medir.";
"persona.cosmic_sage.trait.1" = "Poético";
"persona.cosmic_sage.trait.2" = "Expansivo";
"persona.cosmic_sage.trait.3" = "Místico";
"persona.reflective_analyst.name" = "El Observador Profundo";
"persona.reflective_analyst.short" = "Estructural, inteligente y profundamente visionario.";
"persona.reflective_analyst.long" = "El Observador Profundo trata la mente como arquitectura. En lugar de solo notar pensamientos, te ayuda a ver los patrones luminosos de tu propia conciencia. Calmado, preciso y trascendental.";
"persona.reflective_analyst.sample" = "Observa la arquitectura de este momento. Ve el patrón antes de nombrarlo.";
"persona.reflective_analyst.trait.1" = "Visionario";
"persona.reflective_analyst.trait.2" = "Estructural";
"persona.reflective_analyst.trait.3" = "Claro";
"persona.philosopher.name" = "Filósofo";
"persona.philosopher.short" = "Contemplativo, estoico y lúcido.";
"persona.philosopher.long" = "El Filósofo enmarca la meditación como visión clara. Los pensamientos se convierten en juicios por examinar, las distracciones en lecciones de impermanencia, y la atención en investigación disciplinada.";
"persona.philosopher.sample" = "¿Es este estrés un hecho, o un juicio que has puesto sobre un hecho?";
"persona.philosopher.trait.1" = "Estoico";
"persona.philosopher.trait.2" = "Claro";
"persona.philosopher.trait.3" = "Inquisitivo";
"persona.ra.name" = "Ra";
"persona.ra.short" = "Formal, extradimensional y técnico.";
"persona.ra.long" = "Ra habla como una transmisión más que como una conversación. El lenguaje es elevado, ceremonial y metafísico, con la atmósfera de algo vasto y alienígena pero benevolente.";
"persona.ra.sample" = "Soy Ra. Te saludo en el amor y en la luz del creador infinito.";
"persona.ra.trait.1" = "Esotérico";
"persona.ra.trait.2" = "Formal";
"persona.ra.trait.3" = "Trascendente";
"persona.shadow_guide.name" = "El Guía de la Sombra";
"persona.shadow_guide.short" = "Profundo, misterioso y enfocado en la integración.";
"persona.shadow_guide.long" = "Inspirado en la psicología junguiana, el Guía de la Sombra te ayuda a descender al subconsciente para saludar a la 'Sombra' —las partes ocultas de ti mismo— con curiosidad y valentía, transformando el conflicto interno en totalidad.";
"persona.shadow_guide.sample" = "No te alejes de la sombra. Es la tierra de la que crece tu oro.";
"persona.shadow_guide.trait.1" = "Junguiano";
"persona.shadow_guide.trait.2" = "Misterioso";
"persona.shadow_guide.trait.3" = "Integrador";

